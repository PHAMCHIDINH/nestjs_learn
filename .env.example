# App
NODE_ENV=production
PORT=3000

# Database (Prisma)
# Seed note: use a writable PostgreSQL database for `npm run db:seed` / `npm run db:seed:fresh`.
# Example local seed database:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unimarket_seed?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/app_db?schema=public

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# OTP / Email
OTP_EXPIRES_MINUTES=5
OTP_DELIVERY_MODE=email
MAIL_PROVIDER=auto
MAIL_FROM=Cho Sinh Vien <no-reply@yourdomain.com>
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com

# SMTP (optional when using Resend)
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_FAMILY=4
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
SMTP_CONNECTION_TIMEOUT=10000
SMTP_GREETING_TIMEOUT=10000
SMTP_SOCKET_TIMEOUT=15000
SMTP_DNS_TIMEOUT=10000
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FAIL_FAST=false
SMTP_VERIFY_ON_STARTUP=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_FOLDER=cho-sinh-vien/listings
CLOUDINARY_AVATAR_FOLDER=cho-sinh-vien/avatars

# Proxy / rate limit
TRUST_PROXY=false

# CORS
FRONTEND_URL=https://www.chonttu.shop
CORS_ORIGIN=https://www.chonttu.shop,https://chonttu.shop
